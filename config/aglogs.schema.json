{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/grovetools/agentlogs/config/config",
  "$defs": {
    "TranscriptConfig": {
      "properties": {
        "detail_level": {
          "type": "string",
          "enum": [
            "summary",
            "full"
          ],
          "description": "Verbosity of transcript output: summary or full",
          "default": "summary",
          "x-layer": "global",
          "x-priority": "60"
        },
        "max_diff_lines": {
          "type": "integer",
          "description": "Lines of diff to show before truncating (0=unlimited)",
          "default": 0,
          "x-layer": "global",
          "x-priority": "61"
        }
      },
      "type": "object"
    }
  },
  "properties": {
    "transcript": {
      "$ref": "#/$defs/TranscriptConfig",
      "description": "Transcript viewing settings",
      "x-layer": "global",
      "x-priority": "60"
    }
  },
  "type": "object",
  "title": "Grove Agent Logs (aglogs) Configuration",
  "description": "Schema for the 'aglogs' extension in grove.yml."
}